# Teacher passcode (optional at build time — Vite reads VITE_* when you run build/dev).
# If unset, the app uses public/app-config.json, then default "teacher123".
#
# Local: copy to .env.local and restart npm run dev
# VITE_TEACHER_PASSCODE=teacher123
#
# Netlify: Site settings → Environment variables → same key, then redeploy
# Or edit public/app-config.json and redeploy (no env var needed)
